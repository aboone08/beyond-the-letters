    "myths": [
      {
        "id": 1,
        "question": "Is the Divine Nine only for undergraduate students?",
        "answer": "No. All NPHC organizations have graduate and alumni chapters for professionals to join and serve later in life."
      },
      {
        "id": 2,
        "question": "Are these organizations only focused on social events?",
        "answer": "While social bonding is a part of the experience, the primary focus of the Divine Nine is community service, social action, and scholarship."
      },
      {
        "id": 3,
        "question": "Do you have to be Black to join a D9 organization?",
        "answer": "No. While they are historically Black organizations founded to support Black students, they are non-discriminatory and open to individuals of all backgrounds who support their mission."
      },
      {
        "id": 4,
        "question": "Are all nine organizations fraternities?",
        "answer": "No. The Divine Nine consists of five fraternities and four sororities."
      },
      {
        "id": 5,
        "question": "Can you belong to more than one NPHC organization?",
        "answer": "No. Membership in an NPHC organization is a lifelong commitment, and individuals may only hold membership in one of the nine organizations."
      },
      {
        "id": 6,
        "question": "Is the Divine Nine a secret society?",
        "answer": "They are 'societies with secrets.' While their rituals and internal symbols are private, their missions, members, and service work are very public."
      },
      {
        "id": 7,
        "question": "Was the Divine Nine founded all at once?",
        "answer": "No. The organizations were founded independently between 1906 and 1963. The NPHC was formed in 1930 to coordinate their efforts."
      },
      {
        "id": 8,
        "question": "Are 'Divine Nine' and 'NPHC' the same thing?",
        "answer": "The NPHC is the governing body; the 'Divine Nine' is the popular name for the group of organizations it represents."
      },
      {
        "id": 9,
        "question": "Is 'stepping' or 'strolling' required for all members?",
        "answer": "While stepping and strolling are iconic cultural traditions within the organizations, participation is usually optional and varies by individual chapter and member interest."
      }
    ]
